{
  "name": "boardgame-timer",
  "version": "0.1.0",
  "private": true,
  "description": "Single-host web app that allocates a clock to each player in a board-game session.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.18 <21"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "mqtt:up": "docker compose up -d mosquitto",
    "mqtt:down": "docker compose down",
    "mqtt:logs": "docker compose logs -f mosquitto",
    "fake-button": "tsx scripts/fake-button.ts",
    "seed:devices": "tsx scripts/seed-devices.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "mqtt": "^5.10.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.16.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitest/coverage-v8": "^2.1.0",
    "aedes": "^1.0.2",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
